# ============================================================
# LLM 后端切换配置
# 复制为 .env 或 .env.local，取消注释要用的预设块即可切换
# 若同时存在 MINIMAX_API_KEY 与本地 Ollama：必须显式 LLM_BACKEND=ollama，否则会走 MiniMax 开放平台（易报配额）。
# ============================================================

# ---------- 预设 1：Ollama 本地（免费，默认） ----------
LLM_BACKEND=ollama
# OLLAMA_MODEL=qwen3.5:9b

# ---------- 预设 1b：Ollama 云端 MiniMax（本机 serve + 云端推理，与本项目 .env.local 默认一致） ----------
# 需 ollama signin + https://ollama.com/settings/keys 创建 OLLAMA_API_KEY（勿与 MINIMAX_API_KEY 混淆）
# 启动: ./scripts/start-ollama-minimax-cloud.sh（会 source 本文件注入 KEY）
# LLM_BACKEND=ollama
# OLLAMA_MODEL=minimax-m2.7:cloud
# OLLAMA_API_KEY=your-ollama-cloud-key

# ---------- 预设 2：MiniMax 云端（国内） ----------
# LLM_BACKEND=minimax
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_API_BASE=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.5

# ---------- 预设 3：MiniMax 云端（海外） ----------
# LLM_BACKEND=minimax
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_API_BASE=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.5

# ---------- 预设 4：DeepSeek ----------
# LLM_BACKEND=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ---------- 预设 5：OpenAI ----------
# LLM_BACKEND=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# ---------- 通用调优（可选） ----------
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=2048
# LLM_TIMEOUT=120
# LLM 失败重试（tenacity）：次数与退避窗口（秒）
# LLM_RETRY_ATTEMPTS=3
# LLM_RETRY_MIN_WAIT=2
# LLM_RETRY_MAX_WAIT=60
# 可选：LLM 调用 JSONL 日志（未设置则不写）
# LLM_CALL_LOG_PATH=data/memory/llm_calls.jsonl
# 综合分析是否注入定量基准分（0/false/no 关闭）
# ANALYSIS_QUANT_BASELINE_ENABLED=1
# Prompt 风格：conservative | neutral | aggressive
# PROMPT_TONE=conservative

# ---------- 美股日终异动 Webhook（scripts/daily_us_movers_webhook.py） ----------
# SCAN_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# SCAN_WEBHOOK_STYLE=feishu
# 可选：dingtalk | slack | generic（默认 generic，与 Slack Incoming Webhook 兼容）
